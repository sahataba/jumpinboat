{
  "name": "@jumpinboat/api",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./next-handlers": {
      "types": "./dist/next-handlers.d.ts",
      "import": "./dist/next-handlers.js"
    },
    "./next-runtime": {
      "types": "./dist/next-runtime.d.ts",
      "import": "./dist/next-runtime.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "db:generate": "node --env-file=.env ../../node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.ts",
    "db:migrate": "node --env-file=.env --import tsx src/db/migrate.ts",
    "db:seed": "node --env-file=.env --import tsx src/db/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@jumpinboat/shared": "*",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.44.5",
    "effect": "^3.19.19",
    "jose": "^6.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
